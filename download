async function callClaude(prompt, expectJson = true) {
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      messages: [{ role: "user", content: prompt }],
    }),
  });
  const data = await response.json();
  if (data.error) throw new Error(data.error.message || "API request failed");
  const text = (data.content || []).map(b => b.text || "").join("\n");
  if (!expectJson) return text.trim();
  const clean = text.replace(/```json|```/g, "").trim();
  if (data.stop_reason === "max_tokens") throw new Error("Response was cut off — run it again");
  return JSON.parse(clean);
}

const planPrompt = (product, industry, segment, timeline, context) => `You are a senior implementation project manager. Generate a phased implementation plan.

INPUTS
Product/service: ${product}
Industry: ${industry}
Customer segment: ${segment}
Target timeline: ${timeline}
Additional context: ${context || "None"}

Respond ONLY with valid JSON, no markdown fences, no preamble. CRITICAL: keep every field extremely terse (5-12 words max per string, except executive_summary). Exactly this shape:
{"plan_title":"<short title>","executive_summary":"<2 sentences: approach + critical success factor>","phases":[{"name":"<2-3 words>","duration":"<e.g. Wk 1-2>","objective":"<one short sentence>","key_activities":["<terse>","<terse>","<terse>"],"exit_criteria":"<short phrase>"}],"raci":[{"workstream":"<short>","responsible":"<role>","accountable":"<role>","consulted":"<role>","informed":"<role>"}],"risks":[{"risk":"<short>","impact":"<2-4 words>","mitigation":"<short phrase>"}],"comms_cadence":[{"meeting":"<short>","frequency":"<e.g. Weekly>","audience":"<short>"}]}

Rules: exactly 4 phases scaled to ${timeline}. Exactly 4 RACI rows. Exactly 3 risks. Exactly 3 comms entries. Tailor to the product, industry, and segment. Compact JSON, no extra whitespace.`;

function Editable({ value, onSave, className, ariaLabel }) {
  const [editing, setEditing] = useState(false);
  const [v, setV] = useState(value);
  useEffect(() => setV(value), [value]);
  if (!editing) {
    return <span className={`editable ${className || ""}`} title="Click to edit" onClick={() => setEditing(true)}>{value}</span>;
  }
  const commit = () => { setEditing(false); if (v.trim() && v !== value) onSave(v.trim()); else setV(value); };
  return (
    <input
      className="editinput" autoFocus value={v} aria-label={ariaLabel || "Edit text"}
      onChange={e => setV(e.target.value)} onBlur={commit}
      onKeyDown={e => { if (e.key === "Enter") commit(); if (e.key === "Escape") { setV(value); setEditing(false); } }}
    />
  );
}

export default function ImplementationPlanGenerator() {
  const [industry, setIndustry] = useState("Logistics / Supply chain");
  const [productChoice, setProductChoice] = useState(PRODUCTS_BY_INDUSTRY["Logistics / Supply chain"][0]);
  const [productCustom, setProductCustom] = useState("");
  const [segment, setSegment] = useState("Mid-market");
  const [timeline, setTimeline] = useState("90 days");
  const [constraintChoice, setConstraintChoice] = useState("None");
  const [constraintCustom, setConstraintCustom] = useState("");
  const [loading, setLoading] = useState(false);
  const [loadIdx, setLoadIdx] = useState(0);
  const [plan, setPlan] = useState(SAMPLE_PLAN);
  const [planMeta, setPlanMeta] = useState("Sample plan — generate your own above");
  const [isSample, setIsSample] = useState(true);
  const [error, setError] = useState(null);
  const [rerolling, setRerolling] = useState(null);
  const [question, setQuestion] = useState("");
  const [qaThread, setQaThread] = useState([]);
  const [asking, setAsking] = useState(false);
  const [critique, setCritique] = useState(null);
  const [critiquing, setCritiquing] = useState(false);
  const [savedPlans, setSavedPlans] = useState([]);
  const [copied, setCopied] = useState(false);

  const copyMarkdown = async () => {
    const md = [
      `# ${plan.plan_title}`,
      `_${isSample ? "Sample plan" : planMeta}_`,
      ``,
      `## Executive Summary`,
      plan.executive_summary,
      ``,
      `## Phases`,
      ...plan.phases.map((p, i) => [
        `### ${i + 1}. ${p.name} (${p.duration})`,
        `*${p.objective}*`,
        ...p.key_activities.map(a => `- ${a}`),
        `**Exit criteria:** ${p.exit_criteria}`,
        ``,
      ].join("\n")),
      `## RACI`,
      `| Workstream | R | A | C | I |`,
      `| --- | --- | --- | --- | --- |`,
      ...plan.raci.map(r => `| ${r.workstream} | ${r.responsible} | ${r.accountable} | ${r.consulted} | ${r.informed} |`),
      ``,
      `## Risk Register`,
      ...plan.risks.map(r => `- **${r.risk}** — Impact: ${r.impact}. Mitigation: ${r.mitigation}`),
      ``,
      `## Comms Cadence`,
      `| Meeting | Frequency | Audience |`,
      `| --- | --- | --- |`,
      ...plan.comms_cadence.map(c => `| ${c.meeting} | ${c.frequency} | ${c.audience} |`),
    ].join("\n");
    try {
      await navigator.clipboard.writeText(md);
    } catch (e) {
      const ta = document.createElement("textarea");
      ta.value = md; document.body.appendChild(ta); ta.select();
      document.execCommand("copy"); document.body.removeChild(ta);
    }
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const isCustomProduct = productChoice === CUSTOM_OPTION;
  const isCustomConstraint = constraintChoice.startsWith("Custom");
  const product = isCustomProduct ? productCustom : productChoice;
  const context = isCustomConstraint ? constraintCustom : (constraintChoice === "None" ? "" : constraintChoice);

  const changeIndustry = (newIndustry) => {
    setIndustry(newIndustry);
    setProductChoice(productsFor(newIndustry)[0]);
    setProductCustom("");
    setConstraintChoice("None");
    setConstraintCustom("");
  };

  useEffect(() => {
    (async () => {
      try {
        const result = await window.storage.get("saved-plans");
        if (result && result.value) setSavedPlans(JSON.parse(result.value));
      } catch (e) { /* no saved plans yet */ }
    })();
  }, []);

  useEffect(() => {
    if (!loading) return;
    const t = setInterval(() => setLoadIdx(i => (i + 1) % LOADING_LINES.length), 2200);
    return () => clearInterval(t);
  }, [loading]);

  const persist = async (plans) => {
    setSavedPlans(plans);
    try { await window.storage.set("saved-plans", JSON.stringify(plans)); }
    catch (e) { console.error("Storage save failed", e); }
  };

  const savePlan = (p, meta) => {
    const entry = { id: Date.now().toString(36), title: p.plan_title, meta, plan: p };
    persist([entry, ...savedPlans].slice(0, 8));
  };

  const updateSavedIfCurrent = (newPlan) => {
    if (isSample) return;
    const idx = savedPlans.findIndex(s => s.title === plan.plan_title || s.title === newPlan.plan_title);
    if (idx >= 0) {
      const next = [...savedPlans];
      next[idx] = { ...next[idx], title: newPlan.plan_title, plan: newPlan };
      persist(next);
    }
  };

  const setPlanAndSync = (updater) => {
    setPlan(prev => {
      const next = typeof updater === "function" ? updater(prev) : updater;
      updateSavedIfCurrent(next);
      return next;
    });
  };

  const loadPlan = (entry) => {
    setPlan(entry.plan); setPlanMeta(entry.meta); setIsSample(false);
    setCritique(null); setQaThread([]); setError(null);
  };

  const deletePlan = (e, id) => {
    e.stopPropagation();
    persist(savedPlans.filter(s => s.id !== id));
  };

  const startNew = () => {
    setPlan(null); setPlanMeta(""); setIsSample(false);
    setCritique(null); setQaThread([]); setQuestion(""); setError(null);
    setIndustry("Logistics / Supply chain");
    setProductChoice(PRODUCTS_BY_INDUSTRY["Logistics / Supply chain"][0]); setProductCustom("");
    setSegment("Mid-market");
    setTimeline("90 days"); setConstraintChoice("None"); setConstraintCustom("");
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const generate = async () => {
    if (!product.trim()) { setError("Describe your custom implementation, or pick one from the list."); return; }
    setLoading(true); setError(null); setQaThread([]); setCritique(null);
    try {
      const result = await callClaude(planPrompt(product, industry, segment, timeline, context));
      const meta = `${industry} · ${segment} · ${timeline}`;
      setPlan(result); setPlanMeta(meta); setIsSample(false);
      savePlan(result, meta);
    } catch (e) {
      setError(`Plan generation failed: ${e.message}. Run it again.`);
    } finally {
      setLoading(false);
    }
  };

  const reroll = async (section) => {
