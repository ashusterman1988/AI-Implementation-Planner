                <h3>Risk Register</h3><span className="mono">Top exposures, ranked</span>
                <button className="reroll" onClick={() => reroll("risks")} disabled={!!rerolling}>{rerolling === "risks" ? "Re-rolling..." : "Re-roll"}</button>
              </div>
              {plan.risks.map((r, i) => (
                <div className="risk" key={i}>
                  <div className="rname"><Editable value={r.risk} onSave={v => updRisk(i, "risk", v)} /></div>
                  <p><b>Impact:</b> <Editable value={r.impact} onSave={v => updRisk(i, "impact", v)} /> · <b>Mitigation:</b> <Editable value={r.mitigation} onSave={v => updRisk(i, "mitigation", v)} /></p>
                </div>
              ))}
            </section>

            <section className="section">
              <div className="sechead">
                <h3>Comms Cadence</h3><span className="mono">Governance rhythm</span>
                <button className="reroll" onClick={() => reroll("comms_cadence")} disabled={!!rerolling}>{rerolling === "comms_cadence" ? "Re-rolling..." : "Re-roll"}</button>
              </div>
              <table>
                <thead><tr><th>Meeting</th><th>Frequency</th><th>Audience</th></tr></thead>
                <tbody>
                  {plan.comms_cadence.map((c, i) => (
                    <tr key={i}>
                      <td><Editable value={c.meeting} onSave={v => updComms(i, "meeting", v)} /></td>
                      <td><Editable value={c.frequency} onSave={v => updComms(i, "frequency", v)} /></td>
                      <td><Editable value={c.audience} onSave={v => updComms(i, "audience", v)} /></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </section>

            <section className="section qa">
              <div className="sechead"><h3>Ask the Planner</h3><span className="mono">Pressure-test this plan</span></div>
              <div className="qa-thread">
                {qaThread.map((item, i) => (
                  <div className="qa-item" key={i}>
                    <div className="qa-q">{item.q}</div>
                    <div className="qa-a">{item.a}</div>
                  </div>
                ))}
              </div>
              <div className="qa-row">
                <input type="text" value={question} onChange={e => setQuestion(e.target.value)} onKeyDown={e => { if (e.key === "Enter") ask(); }} placeholder="e.g. What if the timeline slips to 6 months?" aria-label="Ask a question about this plan" />
                <button onClick={ask} disabled={asking || !question.trim()}>{asking ? "Thinking..." : "Ask"}</button>
              </div>
            </section>

            <div className="about">
              <h5>About the builder</h5>
              <p><b>Aleksandr Shusterman, PMP, CSM.</b> Senior implementation project manager with 10+ years delivering complex rollouts in global logistics and healthcare operations, currently leading North America implementations at A.P. Moller Maersk across ocean, air, e-commerce, and ground freight. Microsoft Azure AI certified.</p>
              <p className="about-second">I built this agent to put real delivery methodology into AI: phase gates, clear ownership, honest risk registers. The same discipline I bring to every go-live. <b>LinkedIn: linkedin.com/in/aleksandr-shusterman-61326374</b></p>
            </div>
          </main>
        )}
      </div>
    </div>
  );
}
