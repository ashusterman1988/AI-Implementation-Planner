    try {
      const result = await callClaude(`You are a senior implementation PM. For this implementation: ${plan.plan_title} (${planMeta}). Regenerate ONLY this section with a fresh take. Respond ONLY with valid JSON, terse fields, shape: ${shapes[section]}`);
      setPlanAndSync(p => ({ ...p, [section]: result[section] }));
    } catch (e) {
      setError(`Couldn't refresh that section: ${e.message}`);
    } finally {
      setRerolling(null);
    }
  };

  const runCritique = async () => {
    setCritiquing(true); setError(null);
    try {
      const result = await callClaude(`You are a PMO quality reviewer auditing an implementation plan against PMI-style best practice. Plan JSON: ${JSON.stringify(plan)}

Respond ONLY with valid JSON, terse fields: {"score":<integer 0-100, be honest not generous>,"findings":[{"severity":"High|Med|Low","finding":"<what's missing or weak, 5-12 words>","fix":"<concrete fix, 5-12 words>"}]} with exactly 3 findings, most severe first.`);
      setCritique(result);
    } catch (e) {
      setError(`Critique failed: ${e.message}. Try again.`);
    } finally {
      setCritiquing(false);
    }
  };

  const ask = async () => {
    const q = question.trim();
    if (!q) return;
    setAsking(true); setError(null); setQuestion("");
    try {
      const answer = await callClaude(`You are a senior implementation PM. Here is the current implementation plan as JSON: ${JSON.stringify(plan)}

The stakeholder asks: "${q}"

Answer in 2-4 short sentences, plain text, no JSON, no markdown. Be specific to this plan.`, false);
      setQaThread(t => [...t, { q, a: answer }]);
    } catch (e) {
      setError(`Question failed: ${e.message}`);
    } finally {
      setAsking(false);
    }
  };

  const updPhase = (i, field, val) => setPlanAndSync(p => {
    const phases = p.phases.map((ph, j) => j === i ? { ...ph, [field]: val } : ph);
    return { ...p, phases };
  });
  const updActivity = (i, j, val) => setPlanAndSync(p => {
    const phases = p.phases.map((ph, k) => k === i ? { ...ph, key_activities: ph.key_activities.map((a, m) => m === j ? val : a) } : ph);
    return { ...p, phases };
  });
  const updRaci = (i, field, val) => setPlanAndSync(p => ({ ...p, raci: p.raci.map((r, j) => j === i ? { ...r, [field]: val } : r) }));
  const updRisk = (i, field, val) => setPlanAndSync(p => ({ ...p, risks: p.risks.map((r, j) => j === i ? { ...r, [field]: val } : r) }));
  const updComms = (i, field, val) => setPlanAndSync(p => ({ ...p, comms_cadence: p.comms_cadence.map((c, j) => j === i ? { ...c, [field]: val } : c) }));

  return (
