      raci: '{"raci":[{"workstream":"<short>","responsible":"<role>","accountable":"<role>","consulted":"<role>","informed":"<role>"}]} with exactly 4 rows',
      comms_cadence: '{"comms_cadence":[{"meeting":"<short>","frequency":"<e.g. Weekly>","audience":"<short>"}]} with exactly 3 entries',
